# 龙虾出行开放平台 API Token（仅服务端使用，切勿提交或暴露到前端）
# 生产环境真实 token：rdak_live_* 调用会产生真实订单与扣费
LX_API_TOKEN=rdak_live_xxxxxxxxxxxxxxxxxxxxx

# 上游网关
LX_API_BASE=https://api.longxiachuxing.com

# ----- 航线监控（订阅告警）-----
# Bark 推送 key（在 Bark App 里查看；留空则不推送，仅写告警记录）
BARK_KEY=
# Bark 服务器地址（自建可改，默认官方）
BARK_BASE=https://api.day.app
# SQLite 数据库路径（默认 ./data/monitor.db）
DB_PATH=./data/monitor.db
# 监控 cron 表达式（默认每 3 小时："0 */3 * * *"）
CRON_SCHEDULE=0 */3 * * *
# 启动后是否立即扫一次（1=是，0/留空=否）
MONITOR_BOOT_SCAN=0
